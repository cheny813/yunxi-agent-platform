# EditorConfig: 统一项目缩进和编码规范
# 详见 https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.sql]
indent_size = 2

[*.{md,mdr}]
indent_size = 2
trim_trailing_whitespace = false

[*.properties]
indent_size = 0
indent_style = tab

[Makefile]
indent_style = tab